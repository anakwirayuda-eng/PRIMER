{
  "name": "primer-game",
  "private": true,
  "version": "0.8.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "build": "vite build",
    "lint": "eslint \"src/**/*.{js,jsx}\" --max-warnings=0",
    "lint:core": "eslint \"src/**/*.{js,jsx}\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "lint:full": "eslint . --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.{js,jsx}\" --fix",
    "lint:json": "node scripts/primera/watchdog-lint-budget.mjs",
    "watchdog:lint": "node scripts/primera/watchdog-lint-budget.mjs",
    "test:unit:json": "vitest run --reporter=json --outputFile=megalog/outputs/vitest.json || exit 0",
    "test:e2e": "playwright test",
    "test:e2e:json": "playwright test --reporter=json > megalog/outputs/playwright.json || exit 0",
    "dep:json": "depcruise src --output-type json > megalog/outputs/depcruise.json || exit 0",
    "knip:json": "knip --reporter json > megalog/outputs/knip.json || exit 0",
    "assets:check": "node scripts/primera/watchdog-assets.mjs",
    "clinical:check": "node scripts/primera/clinical_watchdog.mjs",
    "build:gate": "npm run build || exit 0",
    "prebuild": "node scripts/validate-assets.mjs",
    "validate:assets": "node scripts/validate-assets.mjs",
    "export:textures": "node scripts/export-textures.mjs",
    "megalog": "node scripts/primera/megalog_v5.mjs",
    "diag:export": "node scripts/primera/pldb_exporter.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "framer-motion": "^12.34.2",
    "i18next": "^25.7.4",
    "konva": "^10.2.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.3",
    "react-konva": "^19.2.2",
    "react-router-dom": "^7.12.0",
    "recharts": "^3.6.0",
    "seedrandom": "^3.0.5",
    "tailwind-merge": "^3.4.0",
    "three": "^0.183.1",
    "zod": "^3.22.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@size-limit/preset-app": "^11.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.23",
    "dependency-cruiser": "^16.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-security": "^2.1.0",
    "globals": "^16.5.0",
    "jsdom": "^28.0.0",
    "knip": "^4.5.0",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^5.12.0",
    "size-limit": "^11.0.2",
    "tailwindcss": "^3.4.17",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
